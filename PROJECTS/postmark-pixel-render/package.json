{
  "name": "postmark-walk",
  "private": true,
  "version": "0.0.1",
  "description": "Walkable Postmark — the town's interiors, compiled from the town repo. Engine: npcts (pinned dependency, never forked lightly). PoC scope: static config, safe-action dispatcher, no server.",
  "type": "module",
  "scripts": {
    "postinstall": "node tools/patch-npcts.mjs",
    "compile-world": "node tools/compile-world.mjs",
    "dev": "vite",
    "build": "npm run compile-world && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "npcts": "0.1.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
