# only the raw runtime-session lane stays local. (See MEEPS/AGENTS.md § public dorm.)
MEEPS/*/memory/raw/

# Claude runtime — ship the project skills, ignore session/runtime residue
.claude/*
!.claude/skills/
.office-session.lock
